# Copy this file to `.env` and fill in real values.
# NEVER commit real secrets — only this .env.example with placeholders is tracked.

# ── Runtime ───────────────────────────────────────────────
NODE_ENV=development
API_PORT=4000

# ── MongoDB (one cluster connection — no db in the path) ──
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.example.mongodb.net/
PLATFORM_DB_NAME=newscore_platform

# ── Redis (Upstash) ───────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth (JWT access + rotating refresh + OTP) ────────────
# Refresh tokens are opaque random strings stored SHA-256-hashed in the tenant
# DB (not JWTs), so only the access token needs a signing secret.
JWT_ACCESS_SECRET=replace-me-openssl-rand-base64-48   # must be >= 32 chars
JWT_ACCESS_TTL=15m
REFRESH_TTL_DAYS=30
OTP_TTL_SECONDS=300
OTP_LENGTH=6

# ── Encryption key for per-tenant secrets at rest ─────────
SECRETS_ENC_KEY=replace-me-openssl-rand-base64-32   # must be >= 16 chars

# Media (R2/Bunny), comms (Resend/MSG91/FCM) and payments (Razorpay)
# are per-tenant and added in later phases — see CLAUDE.md §3.
