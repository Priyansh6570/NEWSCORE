# Copy this file to `.env` and fill in real values.
# NEVER commit real secrets — only this .env.example with placeholders is tracked.

# ── Runtime ───────────────────────────────────────────────
NODE_ENV=development
API_PORT=3000

# ── Platform DB (MongoDB Atlas, shared registry) ──────────
PLATFORM_DB_URI=mongodb+srv://user:pass@cluster.mongodb.net/platform

# ── Redis (Upstash) ───────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth (JWT + refresh rotation) ─────────────────────────
JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me

# ── Encryption key for per-tenant secrets at rest ─────────
SECRETS_ENC_KEY=change-me

# Media (R2/Bunny), comms (Resend/MSG91/FCM) and payments (Razorpay)
# are per-tenant and added in later phases — see CLAUDE.md §3.
